# ═══════════════════════════════════════════════════════
# ParkiUpar Microservices — Environment Variables
# ═══════════════════════════════════════════════════════

# Supabase
SUPABASE_URL=https://xqgwetpzuslklycflebu.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here

# JWT Secret (min 32 chars, generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=your_jwt_secret_here

# Internal communication secret (generate with: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))")
INTERNAL_SECRET=your_internal_secret_here

# CORS
CORS_ORIGIN=http://localhost:5173

# Environment
NODE_ENV=development
