{
  "compilerOptions": {
    "ignoreDeprecations": "5.0",
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": "../../..",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": true,
    "paths": {
      "../../../../shared/src/*": ["./shared/src/*"],
      "../../../shared/src/*": ["./shared/src/*"]
    },
    "baseUrl": "."
  },
  "include": [
    "src/**/*",
    "shared/src/**/*"
  ],
  "exclude": ["node_modules", "dist"]
}